# ─── Django / Backend ───────────────────────
SECRET_KEY=change-me-in-production-min-50-characters-long-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ───────────────────────────────
DATABASE_URL=postgresql://talleruser:tallerpass@localhost:5433/tallerdb?sslmode=disable

# ─── Redis ──────────────────────────────────
REDIS_URL=redis://localhost:6389/0

# ─── JWT ────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ─── CORS ───────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Frontend ───────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000/api/v1

# ─── Email (opcional) ───────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=noreply@tallerchapa.com

# ─── File Uploads ───────────────────────────
MEDIA_ROOT=backend/media
MEDIA_URL=/media/

# ─── Cloudinary (recomendado para produccion) ─
# Obtén gratis en https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Twilio (WhatsApp / SMS) ────────────────
# Obtén gratis en https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# ─── Environment ────────────────────────────
ENV=development
